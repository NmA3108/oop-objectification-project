@model TestMVC.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container mt-4">
    <h2>Xóa sản phẩm</h2>

    <div class="alert alert-warning">
        Bạn có chắc muốn xóa sản phẩm <strong>@Model.Name</strong> không?
    </div>

    <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id">
        <button class="btn btn-danger">Xóa</button>
        <a class="btn btn-secondary" asp-action="Index">Hủy</a>
    </form>
</div>
