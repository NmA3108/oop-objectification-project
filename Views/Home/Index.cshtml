@model List<TestMVC.Models.Product>

<div class="container">

    <div class="p-5 mb-4 bg-light rounded-3 mt-4">

        <div class="container-fluid py-5">

            <h1 class="display-5 fw-bold">
                Hệ thống thương mại điện tử
            </h1>

            <p class="col-md-8 fs-4">
                Tìm kiếm và mua sắm sản phẩm trực tuyến nhanh chóng.
            </p>

            <a href="/Product"
               class="btn btn-primary btn-lg">
                Xem sản phẩm
            </a>
            <a href="/Auth/Login"
               class="btn btn-outline-success btn-lg ms-2">
                Đăng nhập
            </a>

        </div>

    </div>

    <h2 class="mb-4">
        Sản phẩm nổi bật
    </h2>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <img src="@item.ImageUrl"
                         class="card-img-top">

                    <div class="card-body">

                        <h5 class="card-title">
                            @item.Name
                        </h5>

                        <p>
                            @item.Description
                        </p>

                        <h4 class="text-danger">
                            @item.Price.ToString("N0") VNĐ
                        </h4>

                    </div>

                    <div class="card-footer">

                        <a href="/Product"
                           class="btn btn-outline-primary w-100">
                            Xem chi tiết
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>